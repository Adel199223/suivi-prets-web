{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/harness-profile.schema.json",
  "title": "Harness profile",
  "type": "object",
  "required": ["schema_version", "project", "operator", "stack", "bootstrap"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "operator": {
      "type": "object",
      "required": ["experience_level", "preferred_tone", "needs_safe_commands"],
      "properties": {
        "experience_level": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced"]
        },
        "preferred_tone": {
          "type": "string",
          "enum": ["plain_english", "balanced", "technical"]
        },
        "needs_safe_commands": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "stack": {
      "type": "object",
      "required": ["primary_language", "framework", "surfaces", "target_os"],
      "properties": {
        "primary_language": {"type": "string", "minLength": 1},
        "framework": {"type": "string", "minLength": 1},
        "surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "target_os": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "bootstrap": {
      "type": "object",
      "required": [
        "archetype",
        "mode",
        "enabled_modules",
        "disabled_modules",
        "uses_openai",
        "needs_codespaces",
        "has_browser_bridge",
        "notes"
      ],
      "properties": {
        "archetype": {"type": "string", "minLength": 1},
        "mode": {"type": "string", "enum": ["lite", "standard", "full"]},
        "enabled_modules": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "disabled_modules": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "uses_openai": {"type": "boolean"},
        "needs_codespaces": {"type": "boolean"},
        "has_browser_bridge": {"type": "boolean"},
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
