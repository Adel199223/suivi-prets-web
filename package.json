{
  "name": "suivi-prets-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "import:preview": "python3 tooling/import_workbook_preview.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-windows.ps1",
    "validate:agent-docs": "node tooling/validate-agent-docs.mjs",
    "validate:workspace-hygiene": "node tooling/validate-workspace-hygiene.mjs",
    "validate:ui": "node tooling/validate-ui-surface.mjs"
  },
  "dependencies": {
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "fflate": "^0.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.9.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.4",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
